<div class="w-full">
  <%= render partial: "layouts/page_head", locals: {title: "#{@league_team.team.name} - #{@league.name}", description: "Team probability details.", link_path: admin_league_league_teams_path(admin_league_id: @league.id)} %>
  <div class="mt-8">
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Home Probabilities</h2>
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Win</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= number_with_precision(@league_team.home_prob_win, precision: 4) %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Draw</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= number_with_precision(@league_team.home_prob_draw, precision: 4) %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Loss</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= number_with_precision(@league_team.home_prob_loss, precision: 4) %></dd>
        </div>
      </dl>

      <h2 class="text-lg font-semibold text-gray-900 mb-4 mt-8">Away Probabilities</h2>
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-3">
        <div>
          <dt class="text-sm font-medium text-gray-500">Win</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= number_with_precision(@league_team.away_prob_win, precision: 4) %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Draw</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= number_with_precision(@league_team.away_prob_draw, precision: 4) %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Loss</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= number_with_precision(@league_team.away_prob_loss, precision: 4) %></dd>
        </div>
      </dl>

      <div class="mt-8">
        <%= form_with url: recalculate_admin_league_league_team_path(admin_league_id: @league.id, id: @league_team.id), method: :post, local: true do |f| %>
          <%= f.submit "Recalculate Probabilities", class: button_primary_classes %>
        <% end %>
      </div>
    </div>
  </div>
</div>
